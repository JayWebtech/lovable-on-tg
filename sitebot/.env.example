# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Paygentic beta — register, status, checkout, wallet (see docs.paywithlocus.com/quickstart-beta):
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api
LOCUS_API_KEY=claw_dev_your_beta_key_here


# Public HTTPS URL of this bot (webhook + success callbacks)
BOT_PUBLIC_URL=https://your-bot-url-here.buildwithlocus.com

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/sitebot

# Admin Telegram user id (numeric) for alerts
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Pricing (USDC)
PRICE_STANDARD_BUILD=1.50
PRICE_DOMAIN_BUILD=3.00

# App
NODE_ENV=development
LOG_LEVEL=info
MAX_BUILDS_PER_HOUR=3
PAYMENT_TIMEOUT_MINUTES=30
SITE_EXPIRY_DAYS=7
HTTP_PORT=8080
